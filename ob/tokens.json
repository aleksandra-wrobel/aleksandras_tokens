{
  "Base Tokens": {
    "color": {
      "primary": {
        "base": {
          "$value": "#9ea0af",
          "$type": "color"
        },
        "hover": {
          "$value": "#70798c",
          "$type": "color"
        }
      },
      "secondary": {
        "base": {
          "$value": "#a6988b",
          "$type": "color"
        },
        "hover": {
          "$value": "#776d61",
          "$type": "color"
        }
      }
    },
    "fontFamilies": {
      "inter": {
        "$value": "Inter",
        "$type": "fontFamilies"
      }
    },
    "lineHeights": {
      "0": {
        "$value": "AUTO",
        "$type": "lineHeights"
      },
      "1": {
        "$value": "AUTO",
        "$type": "lineHeights"
      }
    },
    "fontWeights": {
      "inter-0": {
        "$value": "Bold",
        "$type": "fontWeights"
      },
      "inter-1": {
        "$value": "Regular",
        "$type": "fontWeights"
      }
    },
    "fontSize": {
      "0": {
        "$value": 32,
        "$type": "fontSizes"
      },
      "1": {
        "$value": 40,
        "$type": "fontSizes"
      }
    },
    "letterSpacing": {
      "0": {
        "$value": "0%",
        "$type": "letterSpacing"
      }
    },
    "paragraphSpacing": {
      "0": {
        "$value": 0,
        "$type": "paragraphSpacing"
      }
    },
    "font": {
      "heading": {
        "h1": {
          "$value": {
            "fontFamily": "{fontFamilies.inter}",
            "fontWeight": "{fontWeights.inter-0}",
            "lineHeight": "{lineHeights.0}",
            "fontSize": "{fontSize.1}",
            "letterSpacing": "{letterSpacing.0}",
            "paragraphSpacing": "{paragraphSpacing.0}",
            "paragraphIndent": "{paragraphIndent.0}",
            "textCase": "{textCase.none}",
            "textDecoration": "{textDecoration.none}"
          },
          "$type": "typography"
        }
      },
      "body": {
        "regular": {
          "$value": {
            "fontFamily": "{fontFamilies.inter}",
            "fontWeight": "{fontWeights.inter-1}",
            "lineHeight": "{lineHeights.0}",
            "fontSize": "{fontSize.0}",
            "letterSpacing": "{letterSpacing.0}",
            "paragraphSpacing": "{paragraphSpacing.0}",
            "paragraphIndent": "{paragraphIndent.0}",
            "textCase": "{textCase.none}",
            "textDecoration": "{textDecoration.none}"
          },
          "$type": "typography"
        }
      }
    },
    "textCase": {
      "none": {
        "$value": "none",
        "$type": "textCase"
      }
    },
    "textDecoration": {
      "none": {
        "$value": "none",
        "$type": "textDecoration"
      }
    },
    "paragraphIndent": {
      "0": {
        "$value": "0px",
        "$type": "dimension"
      }
    }
  }
}
